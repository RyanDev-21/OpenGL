{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch OpenGL",
            "type": "cppdbg",
            "request": "launch",
            // Point this to your actual compiled executable
            "program": "${workspaceFolder}/build/LittleTriangle", 
            "args": [],
            "stopAtEntry": false,
            // THIS IS THE FIX: Set the working directory to the build folder
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: build" // Optional: runs your build before debugging
        }
    ]
}